# Environment variables for the LLM-Powered File System Assistant

# LLM provider to use (e.g., "gemini", "openai", etc.)
LLM_PROVIDER="gemini"

# API key for the Gemini LLM provider
GEMINI_API_KEY="your_gemini_api_key_here"

# API key for OpenAI LLM provider (if using OpenAI)
# OPENAI_API_KEY="your_openai_api_key_here"